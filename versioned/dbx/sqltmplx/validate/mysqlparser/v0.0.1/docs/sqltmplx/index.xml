&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#a6e22e"&gt;bound&lt;/span&gt;, &lt;span style="color:#a6e22e"&gt;err&lt;/span&gt; &lt;span style="color:#f92672"&gt;:=&lt;/span&gt; &lt;span style="color:#a6e22e"&gt;engine&lt;/span&gt;.&lt;span style="color:#a6e22e"&gt;Render&lt;/span&gt;(&lt;span style="color:#a6e22e"&gt;tpl&lt;/span&gt;, &lt;span style="color:#a6e22e"&gt;Query&lt;/span&gt;{
