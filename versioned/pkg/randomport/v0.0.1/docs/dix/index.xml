&lt;h2&gt;Example: Runtime Scope&lt;span class="hx:absolute hx:-mt-20" id="example-runtime-scope"&gt;&lt;/span&gt;
&lt;a href="#example-runtime-scope" class="subheading-anchor" aria-label="Permalink for this section"&gt;&lt;/a&gt;&lt;/h2&gt;&lt;div class="hextra-code-block hx:relative hx:mt-6 hx:first:mt-0 hx:group/code"&gt;
&lt;div&gt;&lt;div class="highlight"&gt;&lt;pre tabindex="0" style="color:#f8f8f2;background-color:#272822;-moz-tab-size:4;-o-tab-size:4;tab-size:4;-webkit-text-size-adjust:none;"&gt;&lt;code class="language-go" data-lang="go"&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#a6e22e"&gt;requestScope&lt;/span&gt; &lt;span style="color:#f92672"&gt;:=&lt;/span&gt; &lt;span style="color:#a6e22e"&gt;advanced&lt;/span&gt;.&lt;span style="color:#a6e22e"&gt;Scope&lt;/span&gt;(&lt;span style="color:#a6e22e"&gt;rt&lt;/span&gt;, &lt;span style="color:#e6db74"&gt;&amp;#34;request-42&amp;#34;&lt;/span&gt;, &lt;span style="color:#66d9ef"&gt;func&lt;/span&gt;(&lt;span style="color:#a6e22e"&gt;injector&lt;/span&gt; &lt;span style="color:#a6e22e"&gt;do&lt;/span&gt;.&lt;span style="color:#a6e22e"&gt;Injector&lt;/span&gt;) {
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; &lt;span style="color:#a6e22e"&gt;advanced&lt;/span&gt;.&lt;span style="color:#a6e22e"&gt;ProvideScopedValue&lt;/span&gt;(&lt;span style="color:#a6e22e"&gt;injector&lt;/span&gt;, &lt;span style="color:#a6e22e"&gt;RequestContext&lt;/span&gt;{&lt;span style="color:#a6e22e"&gt;RequestID&lt;/span&gt;: &lt;span style="color:#e6db74"&gt;&amp;#34;req-42&amp;#34;&lt;/span&gt;})
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; &lt;span style="color:#a6e22e"&gt;advanced&lt;/span&gt;.&lt;span style="color:#a6e22e"&gt;ProvideScoped2&lt;/span&gt;(&lt;span style="color:#a6e22e"&gt;injector&lt;/span&gt;, &lt;span style="color:#66d9ef"&gt;func&lt;/span&gt;(&lt;span style="color:#a6e22e"&gt;cfg&lt;/span&gt; &lt;span style="color:#a6e22e"&gt;AppConfig&lt;/span&gt;, &lt;span style="color:#a6e22e"&gt;req&lt;/span&gt; &lt;span style="color:#a6e22e"&gt;RequestContext&lt;/span&gt;) &lt;span style="color:#a6e22e"&gt;ScopedService&lt;/span&gt; {
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; &lt;span style="color:#66d9ef"&gt;return&lt;/span&gt; &lt;span style="color:#a6e22e"&gt;ScopedService&lt;/span&gt;{&lt;span style="color:#a6e22e"&gt;Config&lt;/span&gt;: &lt;span style="color:#a6e22e"&gt;cfg&lt;/span&gt;, &lt;span style="color:#a6e22e"&gt;Request&lt;/span&gt;: &lt;span style="color:#a6e22e"&gt;req&lt;/span&gt;}
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; })
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;})
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#a6e22e"&gt;svc&lt;/span&gt;, &lt;span style="color:#a6e22e"&gt;err&lt;/span&gt; &lt;span style="color:#f92672"&gt;:=&lt;/span&gt; &lt;span style="color:#a6e22e"&gt;advanced&lt;/span&gt;.&lt;span style="color:#a6e22e"&gt;ResolveScopedAs&lt;/span&gt;[&lt;span style="color:#a6e22e"&gt;ScopedService&lt;/span&gt;](&lt;span style="color:#a6e22e"&gt;requestScope&lt;/span&gt;)
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#66d9ef"&gt;if&lt;/span&gt; &lt;span style="color:#a6e22e"&gt;err&lt;/span&gt; &lt;span style="color:#f92672"&gt;!=&lt;/span&gt; &lt;span style="color:#66d9ef"&gt;nil&lt;/span&gt; {
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; panic(&lt;span style="color:#a6e22e"&gt;err&lt;/span&gt;)
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;}
